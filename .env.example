ANTHROPIC_API_KEY=your_anthropic_api_key_here

# LemonSqueezy – get your store checkout URL from app.lemonsqueezy.com
# Format: https://your-store.lemonsqueezy.com/checkout/buy/your-variant-id
NEXT_PUBLIC_LEMONSQUEEZY_CHECKOUT_URL=https://your-store.lemonsqueezy.com/checkout/buy/your-variant-id

# LemonSqueezy webhook signing secret (from LS dashboard → Webhooks)
LEMONSQUEEZY_WEBHOOK_SECRET=your_webhook_secret_here

# Public URL of this app (used in success/cancel redirects)
NEXT_PUBLIC_APP_URL=https://readme-gen-sable.vercel.app
